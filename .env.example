# ─── Copie ce fichier en .env et remplis les valeurs ─────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=change_cette_cle_secrete_en_production
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@nanaraff.com
ADMIN_PASSWORD=TonMotDePasseAdmin

# PostgreSQL (Railway l'injecte automatiquement - ne pas modifier en prod)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# SQLite local (utilisé automatiquement si DATABASE_URL absent)
# DB_PATH=./data/nanaraff.sqlite
